generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  username        String?   @unique
  avatar          String?
  password        String?
  provider        String?
  providerId      String?
  emailVerifiedAt DateTime?
  userStatus      Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  roles            UserRole[]
  composedMessages AdminComposer[]

  @@map("users")
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  name      String   @unique
  route     String?
  guardName String   @default("web")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Customer {
  id               String  @id @default(cuid())
  customerAccount  String  @unique
  customerEmail    String
  customerEmailBcc String?
  customerPhone    String?
  termsOfPayment   String?
  messageType      String?
  poNumber         String?
  userId           String?

  sales          Sale[]
  invoices       Invoice[]
  messagesStatus MessageStatus[]

  @@map("customers")
}

model Sale {
  id                            String   @id @default(cuid())
  invoiceNumber                 String
  invoiceDate                   String
  customerAccount               String
  customerName                  String?
  address1                      String?
  address2                      String?
  town                          String?
  country                       String?
  postcode                      String?
  customerAccount2              String?
  items                         String?
  weight                        String?
  invoiceTotal                  String?
  jobNumber                     String?
  jobDate                       String?
  sendingDepot                  String?
  deliveryDepot                 String?
  destination                   String?
  town2                         String?
  postcode2                     String?
  serviceType                   String?
  items2                        String?
  volumeWeight                  String?
  increasedLiabilityCover       String?
  subTotal                      String?
  senderReference               String?
  sendersPostcode               String?
  vatAmount                     String?
  vatPercent                    String?
  percentageFuelSurcharge       String?
  percentageResourcingSurcharge String?
  uploadCode                    String?
  uploadTs                      String?
  msCreated                     Int      @default(0)
  invoiceReady                  Int      @default(0)
  numb1                         String?
  numb2                         String?
  numb3                         String?
  numb4                         String?
  numb5                         String?
  createdAt                     DateTime @default(now())

  customer Customer? @relation(fields: [customerAccount], references: [customerAccount])

  @@map("sales")
}

model Invoice {
  id              String   @id @default(cuid())
  saleId          String?
  customerAccount String
  invoiceNumber   String
  invoiceDate     String
  dueDate         String?
  dateCreated     DateTime @default(now())
  terms           String?
  printer         Int      @default(0)
  poNumber        String?
  batchNo         String?
  emailStatus     Int      @default(0)

  customer Customer? @relation(fields: [customerAccount], references: [customerAccount])

  @@map("invoices")
}

model SaleArchive {
  id                            String   @id @default(cuid())
  invoiceNumber                 String
  invoiceDate                   String
  customerAccount               String
  customerName                  String?
  address1                      String?
  address2                      String?
  town                          String?
  country                       String?
  postcode                      String?
  customerAccount2              String?
  items                         String?
  weight                        String?
  invoiceTotal                  String?
  jobNumber                     String?
  jobDate                       String?
  sendingDepot                  String?
  deliveryDepot                 String?
  destination                   String?
  town2                         String?
  postcode2                     String?
  serviceType                   String?
  items2                        String?
  volumeWeight                  String?
  increasedLiabilityCover       String?
  subTotal                      String?
  senderReference               String?
  sendersPostcode               String?
  vatAmount                     String?
  vatPercent                    String?
  percentageFuelSurcharge       String?
  percentageResourcingSurcharge String?
  uploadCode                    String?
  uploadTs                      String?
  msCreated                     Int      @default(0)
  invoiceReady                  Int      @default(0)
  numb1                         String?
  numb2                         String?
  numb3                         String?
  numb4                         String?
  numb5                         String?
  archivedAt                    DateTime @default(now())

  @@map("sales_archive")
}

model InvoiceArchive {
  id              String   @id @default(cuid())
  originalId      String?
  customerAccount String
  invoiceNumber   String
  invoiceDate     String
  dueDate         String?
  terms           String?
  printer         Int      @default(0)
  poNumber        String?
  emailStatus     Int      @default(0)
  archivedAt      DateTime @default(now())

  @@map("invoices_archive")
}

model Settings {
  id                  String  @id @default(cuid())
  companyName         String  @default("")
  logo                String?
  companyAddress1     String?
  companyAddress2     String?
  state               String?
  city                String?
  postcode            String?
  country             String?
  phone               String?
  fax                 String?
  cemail              String?
  website             String?
  primaryContact      String?
  baseCurrency        String  @default("GBP")
  vatNumber           String?
  invoiceDueDate      Int     @default(30)
  invoiceDuePaymentBy String?
  messageTitle        String?
  defaultMessage      String?
  defaultMessage2     String?
  sendLimit           Int     @default(50)

  @@map("settings")
}

model AdminComposer {
  id          String   @id @default(cuid())
  messageType String?
  toDesc      String?
  userEmail   String?
  fromEmail   String?
  title       String
  message     String
  document    String?
  messageById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messageBy      User?           @relation(fields: [messageById], references: [id])
  messagesStatus MessageStatus[]

  @@map("admin_composer")
}

model MessageStatus {
  id         String    @id @default(cuid())
  messageId  String
  customerId String
  sentStatus Int       @default(0)
  sentAt     DateTime?

  message  AdminComposer @relation(fields: [messageId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("messages_status")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posts")
}

model Upload {
  id                String  @id @default(cuid())
  relatedId         String
  filename          String
  tableKey          String
  uploadTitle       String?
  uploadDescription String?

  @@map("uploads")
}

model JobBatch {
  id        String   @id @default(cuid())
  batchNo   String   @unique
  createdAt DateTime @default(now())

  @@map("job_batches")
}
