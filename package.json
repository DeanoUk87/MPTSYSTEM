{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postbuild": "cp public/.htaccess .next/standalone/.htaccess 2>/dev/null || true && cp app.js .next/standalone/app.js 2>/dev/null || true && find .next/standalone -name '*.db' -delete && find .next/standalone -name '*.db-shm' -delete && find .next/standalone -name '*.db-wal' -delete",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/pdfkit": "^0.13.8",
    "pdfkit": "^0.16.0",
    "@types/nodemailer": "^6.4.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "jose": "^6.2.2",
    "otpauth": "^9.4.0",
    "qrcode": "^1.5.4",
    "lucide-react": "^1.7.0",
    "mysql2": "^3.11.5",
    "next": "^16.1.3",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.7",
    "papaparse": "^5.5.3",
    "prisma": "^6.19.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.1.17",
    "tailwindcss": "^4.1.17",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0"
  }
}
